# Copy to .env and fill in your values
# Windows:  copy env.example .env
# Unix:     cp env.example .env

# This repo covers System 1 (data pipelines) and System 2 (knowledge graph) only.
# System 3 (search agent, FastAPI, LangGraph, UI) lives in a separate repository.

# NCBI API (for FTP downloads and EUtils)
# Get your key from https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# PostgreSQL + Apache AGE (System 2: knowledge graph storage)
# Homebrew Postgres on macOS: PG_USER is your `whoami`, PG_PASSWORD can be empty.
# Windows + Docker Desktop (Phase 3.0 smoke test): use the values from your container.
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_username
PG_PASSWORD=
PG_DBNAME=ncbi_kg

# Storage paths (FTP cache, KGX output, raw intermediate files)
#
# Canonical pattern: keep all downloaded data under this repo's data/ directory.
# If you leave these blank, shared/config.py defaults to repo-root data/,
# ftp_cache/, kgx/, and raw/. Set them explicitly only if you need overrides.
#
# Windows: use forward slashes. pathlib handles them and avoids backslash
# escaping.
#
# Example (Windows laptop):
# DATA_DIR=C:/Users/<you>/agentic-search-data-engineering/data
# FTP_CACHE_DIR=C:/Users/<you>/agentic-search-data-engineering/data/ftp_cache
# KGX_OUTPUT_DIR=C:/Users/<you>/agentic-search-data-engineering/data/kgx
# RAW_DATA_DIR=C:/Users/<you>/agentic-search-data-engineering/data/raw
#
# Example (Linux / macOS):
# DATA_DIR=/path/to/agentic-search-data-engineering/data
# FTP_CACHE_DIR=/path/to/agentic-search-data-engineering/data/ftp_cache
# KGX_OUTPUT_DIR=/path/to/agentic-search-data-engineering/data/kgx
# RAW_DATA_DIR=/path/to/agentic-search-data-engineering/data/raw
DATA_DIR=
FTP_CACHE_DIR=
KGX_OUTPUT_DIR=
RAW_DATA_DIR=
