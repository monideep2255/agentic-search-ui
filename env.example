# Copy to .env and fill in your values
# cp env.example .env

# This repo covers System 1 (data pipelines) and System 2 (knowledge graph) only.
# System 3 (search agent, FastAPI, LangGraph, UI) lives in a separate repository.

# NCBI API (for FTP downloads and EUtils)
# Get your key from https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# PostgreSQL + Apache AGE (System 2: knowledge graph storage)
# On Homebrew Postgres the default superuser is your macOS username with no password.
# Run `whoami` to find PG_USER. PG_PASSWORD can be empty for local Homebrew installs.
PG_HOST=localhost
PG_PORT=5432
PG_USER=your_macos_username
PG_PASSWORD=
PG_DBNAME=ncbi_kg

# Storage paths (FTP cache and KGX output)
FTP_CACHE_DIR=./data/ftp_cache
KGX_OUTPUT_DIR=./data/kgx
