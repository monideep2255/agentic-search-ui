# Copy to .env and fill in your values
# cp env.example .env

# NCBI API
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# Neo4j (local dev)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# LLM API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Redis (caching for Layer 2 ELink calls)
REDIS_URL=redis://localhost:6379

# LangSmith (observability, free tier)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ncbi-agentic-search

# PostHog (analytics, free tier)
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com

# Storage (FTP cache - use local path for dev)
FTP_CACHE_DIR=./data/ftp_cache
KGX_OUTPUT_DIR=./data/kgx

# API
API_KEY=your_internal_api_key_for_fastapi
